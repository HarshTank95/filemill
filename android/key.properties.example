# Release signing config for FileMill.
#
# 1. Create your upload keystore ONCE (keep the .jks and these passwords safe —
#    losing them means you can never update the app on Play again):
#
#      keytool -genkey -v -keystore filemill-upload.jks \
#        -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# 2. Move filemill-upload.jks into the android/ folder (next to this file).
# 3. Copy this file to android/key.properties and fill in your real values.
#
# key.properties and *.jks are git-ignored — they must NEVER be committed.

storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
storeFile=filemill-upload.jks
